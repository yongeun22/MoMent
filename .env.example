# Copy this file to .env for local development overrides.
MOMENT_HOST=127.0.0.1
MOMENT_PORT=8000
MOMENT_MAX_UPLOAD_BYTES=104857600
MOMENT_ADMIN_PATH=/admin
MOMENT_SECURE_COOKIES=auto
# MOMENT_PUBLIC_URL=https://example.com
# MOMENT_ADMIN_URL=https://admin.example.com
# SHA-256 hash used for hidden trace deletion. Do not put the raw password here.
# MOMENT_TRACE_DELETE_PASSWORD_HASH=

# Optional first-run bootstrap admin. Prefer `py manage.py init-admin`.
# MOMENT_ADMIN_USERNAME=admin
# MOMENT_ADMIN_PASSWORD=change-this-password
